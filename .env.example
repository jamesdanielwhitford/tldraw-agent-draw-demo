# Client (Vite) build-time environment. Copy to `.env` and fill in.
# `.env` is gitignored.

# tldraw SDK license key, passed to the <Tldraw> component. Required for any
# public/production deployment (the SDK enforces this client-side); local dev
# works without it. Get one from https://tldraw.dev/pricing (free 100-day trial,
# free hobby license with a "made with tldraw" watermark, or a commercial license).
# Note: this value is inlined into the client bundle at build time and is visible
# to anyone who loads the deployed site, that is expected for tldraw license keys.
VITE_TLDRAW_LICENSE_KEY=
